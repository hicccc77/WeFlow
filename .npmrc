registry=https://registry.npmjs.org

# Sharp (libvips 二进制) - sharp 能正确读取 npm config
sharp_libvips_binary_host=https://ghfast.top/https://github.com/lovell/sharp-libvips/releases/download

# Electron / Electron Builder / ffmpeg-static 的镜像配置
